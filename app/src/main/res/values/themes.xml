<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.T9Launcher" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#A78BFA</item>
        <item name="colorPrimaryVariant">#7C3AED</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#A78BFA</item>
        <item name="colorSecondaryVariant">#7C3AED</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="T9Key" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">66dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:lines">2</item>
        <item name="android:backgroundTint">@color/key_background</item>
        <item name="strokeColor">#4DFFFFFF</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="Theme.T9Launcher.Launcher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.3</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
