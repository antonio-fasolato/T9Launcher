<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.T9Launcher" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#A78BFA</item>
        <item name="colorPrimaryVariant">#7C3AED</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">#A78BFA</item>
        <item name="colorSecondaryVariant">#A78BFA</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.T9Launcher.Launcher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.3</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
